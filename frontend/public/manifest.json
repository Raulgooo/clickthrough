{
  "manifest_version": 3,
  "name": "Clickthrough",
  "version": "0.1.0",
  "description": "Runtime generated overlay interfaces for the current web page.",
  "action": {
    "default_title": "Clickthrough"
  },
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>", "https://api.exa.ai/*", "https://openrouter.ai/*"],
  "background": {
    "service_worker": "assets/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "css": ["assets/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/content.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
